<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Zyra</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Nanum+Myeongjo&family=Roboto:wght@100..900&display=swap" rel="stylesheet">

  <style>
    .custom-navbar {
      padding: 0 50px;
      background-color: #dbcfc5;
    }

    .logo-text {
      font-size: 2.5rem;
      color: #912f2f;
      font-weight: bold;
      font-family: 'Nanum Myeongjo', serif;
    }

    .navbar-nav .nav-link {
      font-size: 0.9rem;
      color: #333;
      margin: 0 6px;
      transition: color 0.3s ease;
      font-family: 'Inter', sans-serif;
    }

    .navbar-nav .nav-link:hover {
      color: #6b2c2c;
    }

    .signup-btn {
      background-color: #b55a35;
      color: #fff;
      border-radius: 6px;
      padding: 6px 14px;
      box-shadow: 0px 2px 6px rgba(0,0,0,0.2);
      transition: background 0.3s ease;
      font-family: 'Roboto', sans-serif;
    }

    .signup-btn:hover {
      background-color: #944828;
      color: #fff;
    }

    .navbar-toggler {
      border: none;
    }

    .navbar-toggler-icon {
      background-image: url("data:image/svg+xml;charset=utf8,%3Csvg viewBox='0 0 30 30' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath stroke='rgba(107,44,44,1)' stroke-width='2' stroke-linecap='round' stroke-miterlimit='10' d='M4 7h22M4 15h22M4 23h22'/%3E%3C/svg%3E");
    }

    .logout-btn {
  border: 1px solid #b55a35;
  color: #b55a35;
  background-color: transparent;
  border-radius: 6px;
  padding: 6px 14px;
  font-family: 'Roboto', sans-serif;
  transition: all 0.3s ease;
}

.logout-btn:hover {
  background-color: #b55a35;
  color: #fff;
}
  </style>
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-light custom-navbar">
  <div class="container-fluid">

    <!-- Logo -->
    <a class="navbar-brand fw-bold logo-text" href="/">ZYRA</a>

    <!-- Hamburger -->
    <button class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#mainNavbar"
        aria-controls="mainNavbar"
        aria-expanded="false"
        aria-label="Toggle navigation"
        onclick="this.blur();">
  <span class="navbar-toggler-icon"></span>
</button>
    <!-- Collapsible Menu -->
    <div class="collapse navbar-collapse justify-content-end" id="mainNavbar">

      <ul class="navbar-nav mb-2 mb-lg-0 align-items-lg-center">

        <li class="nav-item">
          <a class="nav-link" href="/">Home</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/shop">All Products</a>
        </li>

        <% if (user) { %>

        <!-- Wishlist -->
        <li class="nav-item me-2">
          <a class="nav-link ps-3" href="/wishlist">
            <i class="bi bi-heart"></i>
          </a>
        </li>

        <!-- Cart -->
        <li class="nav-item me-2">
          <a class="nav-link position-relative ps-3" href="/getCart">
            <i class="bi bi-cart fs-5"></i>

            <% if (cartCount && cartCount > 0) { %>
              <span class="position-absolute badge rounded-pill bg-danger"
                    style="top: 3px; right: 0px; font-size: 10px;">
                <%= cartCount %>
              </span>
            <% } %>
          </a>
        </li>

        <!-- Profile Link -->
        <li class="nav-item me-3">
          <a href="/profile" class="nav-link d-flex align-items-center">

            <% if (user.profileImage) { %>
              <img src="<%= user.profileImage %>"
                   class="rounded-circle me-2"
                   style="width: 30px; height: 30px; object-fit: cover;">
            <% } else { %>
              <% 
                const name = user.name || "";
                const first = name.charAt(0).toUpperCase();
                const last = name.charAt(name.length - 1).toUpperCase();
                const initials = first + last;
              %>
              <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center me-2"
                   style="width: 30px; height: 30px; font-size: 12px; font-weight: 600;">
                <%= initials %>
              </div>
            <% } %>

            <span><%= user.name %></span>
          </a>
        </li>

        <!-- Logout -->
        <li class="nav-item">
  <a href="/logout" class="btn logout-btn btn-sm">
    Logout
  </a>
</li>

        <% } else { %>

        <!-- Login -->
        <li class="nav-item me-2">
          <a href="/login" class="btn btn-outline-primary">Login</a>
        </li>

        <!-- Signup -->
        <li class="nav-item">
          <a href="/signup" class="btn signup-btn">Sign Up</a>
        </li>

        <% } %>

      </ul>
    </div>
  </div>
</nav>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.addEventListener("DOMContentLoaded", function () {
  const navbar = document.getElementById("mainNavbar");

  navbar.addEventListener("shown.bs.collapse", function () {
    navbar.classList.add("is-open");
  });

  navbar.addEventListener("hidden.bs.collapse", function () {
    navbar.classList.remove("is-open");
  });
});
</script>


</body>
</html>