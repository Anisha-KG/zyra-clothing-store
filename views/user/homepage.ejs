<!-- New Arrivals -->
<section class="container py-5">
  <h2 class="section-title mb-4">New Arrivals</h2>
  <div id="newArrivalsCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">

      <% 
        const chunkSize = 4; // max items per slide for large screens
        for (let i = 0; i < newArrivals.length; i += chunkSize) { 
          const chunk = newArrivals.slice(i, i + chunkSize);
      %>
        <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
          <div class="row">
            <% chunk.forEach(product => { %>
              <div class="col-6 col-sm-4 col-lg-3 mb-3">
                <div class="card product-card shadow-sm border-0 h-100 " onclick="window.location.href='/product/<%= product._id%>'">
                  <% 
                    const matchingVariant = productVariant.find(v => 
                      v.product && v.product._id.toString() === product._id.toString()
                    ); 
                  %>
                  <% if (matchingVariant && matchingVariant.images && matchingVariant.images.length > 0) { %>
  <img src="<%= matchingVariant.images[0].url %>" 
       class="card-img-top" 
       alt="<%= product.name %>">
<% } else { %>
  <img src="/images/placeholder.jpg" 
       class="card-img-top" 
       alt="No image">
<% } %>
                  <div class="card-body text-center">
                    <p class="product-name fw-light mb-1"><%= product.name %></p>
                    <p class="product-price text-muted mb-0">₹<%= product.finalPrice %></p>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#newArrivalsCarousel" data-bs-slide="prev">
      <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#newArrivalsCarousel" data-bs-slide="next">
      <span class="carousel-control-next-icon"></span>
    </button>
  </div>
</section>
  <!-- 🌿 Feature Section -->
  <section class="features-section">
    <div class="container">
      <div class="row gy-4">
        <div class="col-md-4">
          <div class="feature-box">
            <i class="bi bi-truck"></i>
            <h5>Complimentary Shipping</h5>
            <p>Enjoy free delivery on all orders with no hidden charges.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="feature-box">
            <i class="bi bi-flower3"></i>
            <h5>Consciously Crafted</h5>
            <p>Each piece is designed with care and sustainable materials.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="feature-box">
            <i class="bi bi-heart"></i>
            <h5>Ethically Made</h5>
            <p>We support fair labor and eco-friendly production methods.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 🛍 Brand Grid Section -->
  <section class="brand-grid">
    <div class="container">
      <div class="row g-4">
        <div class="col-md-4">
          <div class="brand-card">
            <img src="/images/only.jpg" alt="ONLY">
            <div class="brand-overlay">ONLY</div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="brand-card">
            <img src="/images/taavi.jpg" alt="TAAVI">
            <div class="brand-overlay">TAAVI</div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="brand-card">
            <img src="/images/h&m.jpg" alt="H&M">
            <div class="brand-overlay">H&M</div>
          </div>
        </div>
      </div>
    </div>
  </section>

<!-- Top Trends -->
<section class="container py-5">
  <h2 class="section-title mb-4">Top Trends</h2>

  <div id="topTrendsCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">

      <% 
        const chunkSizes = 4; // max items per slide
        for (let i = 0; i < topTrends.length; i += chunkSizes) { 
          const chunk = topTrends.slice(i, i + chunkSizes);
      %>
        <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
          <div class="row">
            <% chunk.forEach(product => { %>
              <div class="col-6 col-sm-4 col-lg-3 mb-3">
                <div class="card product-card shadow-sm border-0 h-100"  onclick="window.location.href='/product/<%= product._id %>'">
                  <% 
                    const matchingVariant = productVariant.find(v => 
                      v.product && v.product._id.toString() === product._id.toString()
                    ); 
                  %>
                  <% if (matchingVariant && matchingVariant.images && matchingVariant.images.length > 0) { %>
                    <img src="<%= matchingVariant.images[0].url %>" 
       class="card-img-top" 
       alt="<%= product.name %>">
                  <% } else { %>
                    <img src="/images/placeholder.jpg" class="card-img-top" alt="No image">
                  <% } %>
                  <div class="card-body text-center">
                    <p class="product-name fw-semibold mb-1"><%= product.name %></p>
                    <p class="product-price text-muted mb-0">₹<%= product.finalPrice %></p>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#topTrendsCarousel" data-bs-slide="prev">
      <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#topTrendsCarousel" data-bs-slide="next">
      <span class="carousel-control-next-icon"></span>
    </button>
  </div>
</section>
  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>


<%-include("../../views/partials/user/footer")%>