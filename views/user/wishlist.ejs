<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Wishlist</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

  <%- include("../../views/partials/user/header") %>

  <style>
    body { background-color: #fdf6f0; }
    .wishlist-card { border:none; background:white; border-radius:8px; transition:0.3s; }
    .wishlist-card:hover { box-shadow:0 4px 16px rgba(0,0,0,0.1); }
    .wishlist-img { width:100%; height:300px; object-fit:cover; }
    .remove-icon {
      position:absolute; top:8px; right:8px;
      background:white; border-radius:50%;
      width:26px; height:26px;
      display:flex; align-items:center; justify-content:center;
      cursor:pointer; z-index:20;
    }
    .size-btn {
      width:38px; height:38px;
      border:1px solid #ccc;
      border-radius:50%;
      display:flex; align-items:center; justify-content:center;
      cursor:pointer;
    }
    .size-btn.selected {
      background:#912f2f; color:white; border-color:#912f2f;
    }
    .offer-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  background: #ff3f6c;
  color: #fff;
  font-size: 12px;
  font-weight: 700;
  padding: 4px 8px;
  border-radius: 4px;
  z-index: 10;
}

.size-btn {
  width:38px;
  height:38px;
  border:1px solid #ccc;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  transition:0.2s;
}

.size-btn:hover {
  border-color:#912f2f;
}
  </style>
</head>

<body>

<div class="container py-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <button class="btn btn-outline-danger" onclick="location.href='/profile'">Profile</button>
    <h6 class="fw-bold">My Wishlist (<%= totalItems %> items)</h6>
  </div>

  <div class="row g-3">

  <% if (items && items.length > 0) { %>
    <% items.forEach(item => { %>

      <div class="col-6 col-md-4 col-lg-3">
        <div class="wishlist-card position-relative"
             onclick="location.href='/product/<%= item.productId %>'">

              <% if (item.bestOffer && item.bestOffer > 0) { %>
    <div class="offer-badge">
      <%= item.bestOffer %>% OFF
    </div>
  <% } %>

          <span class="remove-icon"
                onclick="event.stopPropagation(); removeWishlist('<%= item.productId %>', '<%= item.color %>')">
            ✕
          </span>

          <img src="<%= item.variant.images[0].url %>" class="wishlist-img">

          <div class="p-2">
            <div><%= item.name %></div>

            <!-- UNIQUE COLOR INPUT -->
            <input type="hidden"
                   id="color-<%= item.productId %>"
                   value="<%= item.color %>">

            <div class="fw-bold">Rs.<%= item.prize %></div>

            <!-- SIZE BOX -->
            <div id="sizeBox-<%= item.productId %>" 
     class="d-flex gap-2 mt-2 flex-wrap"
     style="display:none">

  <% item.availableSizes.forEach(size => { %>
    <div class="size-btn"
         id="sizeBtn-<%= item.productId %>-<%= size %>"
         onclick="event.stopPropagation(); selectSize('<%= item.productId %>', '<%= size %>')">
      <%= size %>
    </div>
  <% }) %>

  <input type="hidden" id="selectedSize-<%= item.productId %>">
</div>

            <button class="btn btn-outline-danger w-100 mt-2"
                    onclick="event.stopPropagation(); handleMoveToCart('<%= item.productId %>')">
              MOVE TO CART
            </button>
          </div>
        </div>
      </div>

    <% }) %>
  <% } else { %>
    <div class="text-center text-muted">No items in wishlist</div>
  <% } %>

  </div>
</div>

 <%- include("../partials/user/footer") %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- ✅ EJS DATA INSIDE SCRIPT -->
<script>
  const wishlistItems = <%- JSON.stringify(items || []) %>;
  console.log("Wishlist items from EJS:", wishlistItems);

  function selectSize(productId, size) {
    document.getElementById(`selectedSize-${productId}`).value = size;
    document.querySelectorAll(`#sizeBox-${productId} .size-btn`)
      .forEach(btn => btn.classList.remove("selected"));
    document.getElementById(`sizeBtn-${productId}-${size}`).classList.add("selected");
  }

  function handleMoveToCart(productId) {
    const box = document.getElementById(`sizeBox-${productId}`);
    const size = document.getElementById(`selectedSize-${productId}`).value;

    if (box.style.display === "none") {
      box.style.display = "block";
      return;
    }

    if (!size) {
      Swal.fire("Select a size first");
      return;
    }

    moveToCart(productId, size);
  }

  async function moveToCart(id, size) {
    const color = document.getElementById(`color-${id}`).value;

    const res = await fetch('/cart/addProduct', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ productId:id, size, color, quantity:1 })
    });

    const result = await res.json();
    Swal.fire(result.message).then(()=>location.reload());
  }

  async function removeWishlist(productId, color) {
    await fetch('/wishlist/toggle', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({productId, color})
    });
    location.reload();
  }
</script>

</body>
</html>

